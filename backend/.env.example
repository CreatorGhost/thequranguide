# theQuranGuide Backend Environment Variables
# Copy to .env and fill in your values

# App
SECRET_KEY=change-me-in-production
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/quran_guide
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/quran_guide

# Redis
REDIS_URL=redis://localhost:6379/0

# AI / LLM Provider
# For OpenAI direct:
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1
LLM_MINI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

# For OpenRouter (alternative):
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-your-key-here
# LLM_MODEL=openai/gpt-4.1

# For Grok (alternative):
# OPENAI_BASE_URL=https://api.x.ai/v1
# OPENAI_API_KEY=xai-your-key-here
# LLM_MODEL=grok-3

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=tafsir_embeddings

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
